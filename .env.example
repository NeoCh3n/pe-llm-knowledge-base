# Mode A: local/self-hosted OpenAI-compatible endpoint (vLLM, Ollama gateway, LM Studio)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_API_KEY=

# Mode B: hosted provider using the same OpenAI client shape
# LLM_PROVIDER=provider
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your_provider_api_key_here

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
DATABASE_URL=sqlite:///./data/app.db
POSTGRES_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pe_memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pe-memory-password
CONNECTORS_ROOT=./data/connectors
